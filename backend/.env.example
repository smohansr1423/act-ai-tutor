# ═══════════════════════════════════════════════════════════════════════════════
# ACT AI Tutor Backend - Environment Variables
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# ─── PostgreSQL Database ───────────────────────────────────────────────────────
# Railway provides DATABASE_URL automatically when you add a PostgreSQL plugin
DATABASE_URL=postgresql://postgres:password@localhost:5432/act_ai_tutor
DB_HOST=localhost
DB_PORT=5432
DB_NAME=act_ai_tutor
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_POOL_MAX=20
DB_POOL_MIN=5

# ─── Redis ─────────────────────────────────────────────────────────────────────
# Railway provides REDIS_URL automatically when you add a Redis plugin
REDIS_URL=redis://localhost:6379

# ─── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here_change_this_to_something_random
JWT_EXPIRES_IN=7d

# ─── LLM Provider (for question generation and AI tutor chat) ──────────────────
# Supports OpenAI or Anthropic
LLM_PROVIDER=openai
LLM_API_KEY=your_api_key_here
LLM_MODEL=gpt-4o-mini
# LLM_PROVIDER=anthropic
# LLM_API_KEY=your_anthropic_api_key_here
# LLM_MODEL=claude-3-haiku-20240307

# ─── CORS (allow your frontend domain) ────────────────────────────────────────
CORS_ORIGIN=*
